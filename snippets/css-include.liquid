<style>
  {%- liquid
    assign base_font = settings.type_base_font
    assign header_font = settings.type_header_font
  -%}

  {{ base_font | font_face: font_display: 'swap' }}
  {{ header_font | font_face: font_display: 'swap' }}

  {%- liquid
    assign base_font_bold = base_font | font_modify: 'weight', 'bolder'
    assign base_font_italic = base_font | font_modify: 'style', 'italic'
    assign base_font_bold_italic = base_font_bold | font_modify: 'style', 'italic'
  -%}

  {%- if base_font_bold -%}
    {{ base_font_bold | font_face: font_display: 'swap' }}
  {%- endif -%}

  {%- if base_font_italic -%}
    {{ base_font_italic | font_face: font_display: 'swap' }}
  {%- endif -%}

  {%- if base_font_bold_italic -%}
    {{ base_font_bold_italic | font_face: font_display: 'swap' }}
  {%- endif -%}
</style>

{{ 'base.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="{{ 'global.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>
  {{ 'global.css' | asset_url | stylesheet_tag }}
</noscript>
{% if template contains 'customers' %}
  <link rel="stylesheet" href="{{ 'account.css' | asset_url }}" media="print" onload="this.media='all'">
  <noscript>
    {{ 'account.css' | asset_url | stylesheet_tag }}
  </noscript>
{% endif %}
{%- if template.suffix == 'late-embers' -%}
  <style>
    @font-face {
      font-family: 'TAY Big Bird';
      src:
        url('{{ "TAYBigBirdRegular.woff2" | asset_url }}') format('woff2'),
        url('{{ "TAYBigBirdRegular.woff" | asset_url }}') format('woff');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }

    body.template-page#late-embers .page-container {
      --font--body: 'TAY Big Bird', sans-serif;
      --font--title: 'TAY Big Bird', sans-serif;
      --font--button: 'TAY Big Bird', sans-serif;
      --font--label: 'TAY Big Bird', sans-serif;
      --font--nav: 'TAY Big Bird', sans-serif;
      --font--body-weight: 400;
      --font--title-weight: 400;
      --font--button-weight: 400;
      --font--label-weight: 400;
      --font--nav-weight: 400;
    }
  </style>
{%- endif -%}
