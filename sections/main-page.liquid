<section class="section section--page page">
  <div class="container container--{{ section.settings.page_width }}">
    <div class="section__title section__title--center js-animate-single" data-animation-displacement="5">
      <h1 class="section__title-text h2">{{ page.title }}</h1>
    </div>
    <div class="page__content rte">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page",
  "settings": [
    {
      "type": "select",
      "id": "page_width",
      "label": "Page width",
      "default": "tiny",
      "options": [
        {
          "label": "Default",
          "value": "large"
        },
        {
          "label": "Narrow",
          "value": "tiny"
        },
        {
          "label": "Wide",
          "value": "wide"
        }
      ]
    }
  ]
}
{% endschema %}
